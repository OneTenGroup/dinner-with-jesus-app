{
  "routes": [
    { "src": "/sw.js", "dest": "/sw.js", "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" } },
    { "src": "/workbox-(.*)\\.js", "dest": "/workbox-$1.js", "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" } },
    { "src": "/manifest.json", "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" }, "continue": true },
    { "src": "/index.html", "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" }, "continue": true },
    { "src": "/assets/(.*)", "headers": { "Cache-Control": "public, max-age=31536000, immutable" }, "continue": true },
    { "src": "/app", "dest": "/index.html" },
    { "src": "/app/(.*)", "dest": "/index.html" },
    { "src": "/table/(.*)", "dest": "/index.html" },
    { "src": "/privacy-policy", "dest": "/privacy-policy.html" },
    { "src": "/terms-of-service", "dest": "/terms-of-service.html" },
    { "src": "/icons/(.*)", "dest": "/icons/$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/jesus-at-table.png", "dest": "/jesus-at-table.png" },
    { "src": "/jesus-welcome.png", "dest": "/jesus-welcome.png" },
    { "src": "/favicon.png", "dest": "/favicon.png" },
    { "src": "/manifest.json", "dest": "/manifest.json" },
    { "src": "^/$", "dest": "/landing.html" },
    { "src": "/delete-account", "dest": "/delete-account.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
